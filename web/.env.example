# Copy to .env and set your local values.
# Base URL of the .NET API — MUST include the /api/v1.0 version segment
# (old-ui REACT_APP_API_URL was http://localhost:6989/api/v1.0). Endpoint
# constants in src/shared/api/endpoints.ts are relative to this.
VITE_API_URL=http://localhost:6989/api/v1.0
# SignalR socket base — host only, NO /api/v1.0 (old-ui REACT_APP_API_SOCKET).
VITE_API_SOCKET=http://localhost:6989
VITE_DEFAULTAUTH=jwt
